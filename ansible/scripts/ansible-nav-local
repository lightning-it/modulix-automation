#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

nav_mode="${ANSIBLE_TOOLBOX_NAV_MODE:-stdout}"
nav_ee_enabled="${ANSIBLE_TOOLBOX_NAV_EE_ENABLED:-false}"
nav_container_engine="${ANSIBLE_TOOLBOX_NAV_CONTAINER_ENGINE:-podman}"
nav_ee_image="${ANSIBLE_TOOLBOX_NAV_EE_IMAGE:-}"
nav_pull_policy="${ANSIBLE_TOOLBOX_NAV_PULL_POLICY:-}"
nav_skip_auth="${ANSIBLE_TOOLBOX_NAV_SKIP_AUTH:-false}"
nav_skip_cert_check="${ANSIBLE_TOOLBOX_NAV_SKIP_CERT_CHECK:-false}"
nav_cache_dir="${ANSIBLE_TOOLBOX_NAV_CACHE_DIR:-/tmp/.cache}"
nav_collection_doc_cache_path="${ANSIBLE_TOOLBOX_NAV_COLLECTION_DOC_CACHE_PATH:-${nav_cache_dir}/ansible-navigator/collection_doc_cache.db}"
if [[ -n "${ANSIBLE_TOOLBOX_AUTO_COLLECTIONS+x}" ]]; then
  auto_collections="${ANSIBLE_TOOLBOX_AUTO_COLLECTIONS}"
elif [[ "${REPO_ROOT}" == "/opt/modulix/ansible" ]]; then
  # RPM/container-in runtime is expected to be self-contained and offline-safe.
  auto_collections="false"
else
  auto_collections="true"
fi
default_collections_requirements="${REPO_ROOT}/collections/requirements.yml"
default_collections_requirements_rh="${REPO_ROOT}/collections/requirements-rh.yml"
collections_requirements="${ANSIBLE_TOOLBOX_COLLECTIONS_REQUIREMENTS:-}"
collections_install_path="${ANSIBLE_TOOLBOX_COLLECTIONS_INSTALL_PATH:-${REPO_ROOT}/collections}"
collections_stamp_file="${ANSIBLE_TOOLBOX_COLLECTIONS_STAMP_FILE:-}"
automation_hub_url="${ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL:-}"
automation_hub_url_published="${ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL_PUBLISHED:-https://console.redhat.com/api/automation-hub/content/published/}"
automation_hub_url_validated="${ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL_VALIDATED:-https://console.redhat.com/api/automation-hub/content/validated/}"
automation_hub_auth_url="${ANSIBLE_TOOLBOX_AUTOMATION_HUB_AUTH_URL:-https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token}"

usage() {
  cat <<'EOF'
Usage:
  ansible-nav-local run <playbook.yml> [ansible-navigator run args...]
  ansible-nav-local exec -- <command> [args...]

Environment:
  ANSIBLE_TOOLBOX_NAV_MODE=stdout|interactive      (default: stdout)
  ANSIBLE_TOOLBOX_NAV_EE_ENABLED=true|false        (default: false)
  ANSIBLE_TOOLBOX_NAV_CONTAINER_ENGINE=podman      (default: podman)
  ANSIBLE_TOOLBOX_NAV_EE_IMAGE=<image:tag>         (default: ansible-navigator config/env)
  ANSIBLE_TOOLBOX_NAV_PULL_POLICY=always|missing|never|tag (default: ansible-navigator config/env)
  ANSIBLE_TOOLBOX_NAV_SKIP_AUTH=true|false         (default: false)
  ANSIBLE_TOOLBOX_NAV_SKIP_CERT_CHECK=true|false   (default: false)
  ANSIBLE_TOOLBOX_NAV_CACHE_DIR=/tmp/.cache        (default: /tmp/.cache)
  ANSIBLE_TOOLBOX_NAV_COLLECTION_DOC_CACHE_PATH=... (default: /tmp/.cache/ansible-navigator/collection_doc_cache.db)
  ANSIBLE_TOOLBOX_AUTO_COLLECTIONS=auto|true|false (default: false in /opt/modulix/ansible RPM mode, true otherwise)
  ANSIBLE_TOOLBOX_COLLECTIONS_REQUIREMENTS=<path>  (default: auto-select requirements-rh.yml if RH_AUTOMATION_HUB_TOKEN is set, else requirements.yml)
  ANSIBLE_TOOLBOX_COLLECTIONS_INSTALL_PATH=<path>  (default: ./collections)
  ANSIBLE_TOOLBOX_COLLECTIONS_STAMP_FILE=<path>    (default: ${ANSIBLE_HOME}/collections.requirements.sha256)
  RH_AUTOMATION_HUB_TOKEN=<token>                  (optional, required for certified collections)
  ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL=<url>         (optional legacy single Automation Hub server URL)
  ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL_PUBLISHED=<url> (optional published server URL)
  ANSIBLE_TOOLBOX_AUTOMATION_HUB_URL_VALIDATED=<url> (optional validated server URL)
EOF
}

case "${nav_mode}" in
  stdout|interactive) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_NAV_MODE='${nav_mode}' (use: stdout|interactive)." >&2
    exit 1
    ;;
esac

case "${nav_ee_enabled}" in
  true|false) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_NAV_EE_ENABLED='${nav_ee_enabled}' (use: true|false)." >&2
    exit 1
    ;;
esac

case "${nav_skip_auth}" in
  true|false) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_NAV_SKIP_AUTH='${nav_skip_auth}' (use: true|false)." >&2
    exit 1
    ;;
esac

case "${nav_skip_cert_check}" in
  true|false) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_NAV_SKIP_CERT_CHECK='${nav_skip_cert_check}' (use: true|false)." >&2
    exit 1
    ;;
esac

case "${auto_collections}" in
  auto|true|false) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_AUTO_COLLECTIONS='${auto_collections}' (use: auto|true|false)." >&2
    exit 1
    ;;
esac

case "${nav_container_engine}" in
  auto|podman|docker) ;;
  *)
    echo "Invalid ANSIBLE_TOOLBOX_NAV_CONTAINER_ENGINE='${nav_container_engine}' (use: auto|podman|docker)." >&2
    exit 1
    ;;
esac

if [[ -n "${nav_pull_policy}" ]]; then
  case "${nav_pull_policy}" in
    always|missing|never|tag) ;;
    *)
      echo "Invalid ANSIBLE_TOOLBOX_NAV_PULL_POLICY='${nav_pull_policy}' (use: always|missing|never|tag)." >&2
      exit 1
      ;;
  esac
fi

if [[ "${nav_skip_auth}" == "true" ]]; then
  unset REGISTRY_AUTH_FILE
fi

hash_file() {
  local file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "${file}" | awk '{print $1}'
    return 0
  fi
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "${file}" | awk '{print $1}'
    return 0
  fi
  if command -v openssl >/dev/null 2>&1; then
    openssl dgst -sha256 "${file}" | awk '{print $NF}'
    return 0
  fi
  cksum "${file}" | awk '{print $1":"$2}'
}

build_galaxy_config_for_certified() {
  local token="$1"
  local config_file=""
  config_file="$(mktemp /tmp/ansible-galaxy.auto.XXXXXX.cfg)"
  if [[ -n "${automation_hub_url}" ]]; then
    cat > "${config_file}" <<EOF
[galaxy]
server_list = automation_hub,galaxy

[galaxy_server.automation_hub]
url = ${automation_hub_url}
auth_url = ${automation_hub_auth_url}
token = ${token}

[galaxy_server.galaxy]
url = https://galaxy.ansible.com/
EOF
  else
    cat > "${config_file}" <<EOF
[galaxy]
server_list = automation_hub_published,automation_hub_validated,galaxy

[galaxy_server.automation_hub_published]
url = ${automation_hub_url_published}
auth_url = ${automation_hub_auth_url}
token = ${token}

[galaxy_server.automation_hub_validated]
url = ${automation_hub_url_validated}
auth_url = ${automation_hub_auth_url}
token = ${token}

[galaxy_server.galaxy]
url = https://galaxy.ansible.com/
EOF
  fi
  printf '%s\n' "${config_file}"
}

ensure_base_collections() {
  local mode="$1"
  local requirements_file="$2"
  local target_path="$3"
  local stamp_file="$4"
  local install_reason=""
  local current_hash=""
  local stored_hash=""
  local needs_certified_collections=false
  local galaxy_config_file=""

  case "${mode}" in
    false)
      return 0
      ;;
    true)
      if [[ ! -f "${requirements_file}" ]]; then
        echo "Missing collections requirements file: ${requirements_file}" >&2
        return 1
      fi
      install_reason="forced by ANSIBLE_TOOLBOX_AUTO_COLLECTIONS=true"
      ;;
    auto)
      if [[ ! -f "${requirements_file}" ]]; then
        return 0
      fi
      if [[ ! -d "${target_path}/ansible_collections" ]]; then
        install_reason="collections cache is missing"
      else
        current_hash="$(hash_file "${requirements_file}")"
        if [[ ! -f "${stamp_file}" ]]; then
          install_reason="requirements stamp is missing"
        else
          stored_hash="$(< "${stamp_file}")"
          if [[ "${stored_hash}" != "${current_hash}" ]]; then
            install_reason="requirements changed"
          fi
        fi
      fi
      ;;
  esac

  if [[ -z "${install_reason}" ]]; then
    return 0
  fi

  mkdir -p "${target_path}"
  echo "Installing base collections (${install_reason})."

  if grep -Eq "name:[[:space:]]*(ansible\\.controller|ansible\\.eda|ansible\\.hub|infra\\.|redhat\\.satellite)" "${requirements_file}" 2>/dev/null; then
    needs_certified_collections=true
  fi

  if [[ "${needs_certified_collections}" == true ]]; then
    if [[ -z "${RH_AUTOMATION_HUB_TOKEN:-}" ]]; then
      echo "Warning: certified collections detected in ${requirements_file} but RH_AUTOMATION_HUB_TOKEN is not set." >&2
      echo "Warning: collection install may fail unless Automation Hub auth is configured elsewhere." >&2
    else
      galaxy_config_file="$(build_galaxy_config_for_certified "${RH_AUTOMATION_HUB_TOKEN}")"
    fi
  fi

  if [[ -n "${galaxy_config_file}" ]]; then
    ANSIBLE_CONFIG="${galaxy_config_file}" ansible-galaxy collection install \
      -r "${requirements_file}" \
      -p "${target_path}" \
      --force
    rm -f "${galaxy_config_file}"
  else
    ansible-galaxy collection install \
      -r "${requirements_file}" \
      -p "${target_path}" \
      --force
  fi

  current_hash="${current_hash:-$(hash_file "${requirements_file}")}"
  printf '%s\n' "${current_hash}" > "${stamp_file}"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

default_ansible_config="${REPO_ROOT}/ansible.cfg"
if [[ -f "/runner/project/ansible.cfg" ]]; then
  default_ansible_config="/runner/project/ansible.cfg"
fi

export HOME="${HOME:-/runner}"
export ANSIBLE_HOME="${ANSIBLE_HOME:-/tmp/.ansible}"
export ANSIBLE_GALAXY_CACHE_DIR="${ANSIBLE_GALAXY_CACHE_DIR:-${ANSIBLE_HOME}/galaxy_cache}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-${nav_cache_dir}}"
export ANSIBLE_NAVIGATOR_COLLECTION_DOC_CACHE_PATH="${ANSIBLE_NAVIGATOR_COLLECTION_DOC_CACHE_PATH:-${nav_collection_doc_cache_path}}"
export ANSIBLE_CONFIG="${ANSIBLE_CONFIG:-${default_ansible_config}}"
export ANSIBLE_LOCAL_TEMP="${ANSIBLE_LOCAL_TEMP:-/tmp}"
export ANSIBLE_REMOTE_TEMP="${ANSIBLE_REMOTE_TEMP:-/tmp}"
legacy_collections_path_default="/usr/share/ansible/collections:/usr/share/automation-controller/collections:/runner/project/collections-dev:/runner/project/collections:/runner/collections"
# Include both workspace-local and EE-mounted project paths.
# In RPM baseline mode, REPO_ROOT is /opt/modulix/ansible in toolbox, while
# the nested EE sees the same project under /runner/project.
dynamic_collections_path_default="${REPO_ROOT}/collections-dev:${REPO_ROOT}/collections:/runner/project/collections-dev:/runner/project/collections:/usr/share/ansible/collections:/usr/share/automation-controller/collections:/runner/collections"
if [[ -z "${ANSIBLE_COLLECTIONS_PATH:-}" || "${ANSIBLE_COLLECTIONS_PATH}" == "${legacy_collections_path_default}" ]]; then
  export ANSIBLE_COLLECTIONS_PATH="${dynamic_collections_path_default}"
else
  export ANSIBLE_COLLECTIONS_PATH
fi
mkdir -p "${ANSIBLE_HOME}" "${ANSIBLE_GALAXY_CACHE_DIR}"
if [[ -z "${collections_stamp_file}" ]]; then
  collections_stamp_file="${ANSIBLE_HOME}/collections.requirements.sha256"
fi

subcommand="$1"
shift

case "${subcommand}" in
  run)
    if [[ $# -lt 1 ]]; then
      echo "Missing playbook path for 'run'." >&2
      usage
      exit 1
    fi
    effective_collections_requirements="${collections_requirements}"
    if [[ -z "${effective_collections_requirements}" ]]; then
      effective_collections_requirements="${default_collections_requirements}"
      if [[ -n "${RH_AUTOMATION_HUB_TOKEN:-}" && -f "${default_collections_requirements_rh}" ]]; then
        effective_collections_requirements="${default_collections_requirements_rh}"
      fi
    fi
    echo "Using collections requirements: ${effective_collections_requirements}"
    ensure_base_collections \
      "${auto_collections}" \
      "${effective_collections_requirements}" \
      "${collections_install_path}" \
      "${collections_stamp_file}"
    if [[ "${nav_pull_policy}" != "never" && "${nav_skip_cert_check}" == "true" && -n "${nav_ee_image}" && "${nav_ee_image}" != localhost/* ]]; then
      if [[ "${nav_container_engine}" == "docker" ]]; then
        echo "ANSIBLE_TOOLBOX_NAV_SKIP_CERT_CHECK=true is only supported with podman engine." >&2
        exit 1
      fi
      pre_pull_args=( --tls-verify=false )
      if [[ "${nav_skip_auth}" == "true" ]]; then
        echo "Pre-pulling EE image with TLS verification disabled (anonymous): ${nav_ee_image}" >&2
        env -u REGISTRY_AUTH_FILE podman pull "${pre_pull_args[@]}" "${nav_ee_image}" >/dev/null
      else
        echo "Pre-pulling EE image with TLS verification disabled: ${nav_ee_image}" >&2
        podman pull "${pre_pull_args[@]}" "${nav_ee_image}" >/dev/null
      fi
    fi
    cmd=(ansible-navigator --mode "${nav_mode}" --cdcp "${nav_collection_doc_cache_path}")
    cmd+=(--ce "${nav_container_engine}")
    # In RPM/runtime mode, playbooks live under /opt/modulix. Mirror that path
    # into the nested EE so imported playbooks resolve correctly.
    if [[ "${nav_ee_enabled}" == "true" && "${REPO_ROOT}" == "/opt/modulix/ansible" && -d "/opt/modulix" ]]; then
      cmd+=(--eev "/opt/modulix:/opt/modulix:Z")
    fi
    if [[ -n "${nav_ee_image}" ]]; then
      cmd+=(--eei "${nav_ee_image}")
    fi
    if [[ -n "${nav_pull_policy}" ]]; then
      cmd+=(--pp "${nav_pull_policy}")
    fi
    if [[ "${nav_ee_enabled}" == "false" ]]; then
      cmd+=(--ee false)
    fi
    cmd+=(run "$@")
    exec "${cmd[@]}"
    ;;
  exec)
    if [[ "${1:-}" == "--" ]]; then
      shift
    fi
    if [[ $# -eq 0 ]]; then
      exec /bin/bash
    fi
    exec "$@"
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    echo "Unsupported subcommand '${subcommand}'. Use 'run' or 'exec'." >&2
    usage
    exit 1
    ;;
esac
